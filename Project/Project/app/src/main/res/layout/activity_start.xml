<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/star_bg">

    <!-- Title at top -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_gravity="top|center_horizontal"
        android:paddingTop="48dp">

        <TextView
            android:id="@+id/game_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="== VOID WALKER =="
            android:textColor="#00FF00"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="monospace"
            android:shadowColor="#00FF00"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="10" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="[RECOLLECTION]"
            android:textColor="#00AA00"
            android:textSize="18sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- 4 buttons centered in the middle of the screen -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="center">

        <Button
            android:id="@+id/btn_start"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:text="> START GAME"
            android:backgroundTint="#1A1A1A"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn_isekai_direct"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:text="> GO TO ISEKAI"
            android:backgroundTint="#004D40"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:text="> SETTINGS"
            android:backgroundTint="#1A1A1A"
            android:textColor="#00FF00"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_others"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:text="> OTHERS"
            android:backgroundTint="#1A1A1A"
            android:textColor="#00FF00"
            android:fontFamily="monospace" />

    </LinearLayout>
</FrameLayout>